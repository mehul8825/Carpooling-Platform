generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  role          String         @default("EMPLOYEE") // ADMIN or EMPLOYEE
  username      String?        @unique
  phone         String?        @unique
  email         String?        @unique
  name          String?
  password      String?
  otp           String?
  otpExpiry     DateTime?
  forcePasswordChange Boolean @default(false)
  driverProfile DriverProfile?
  wallet        Wallet?
  
  vehicles          Vehicle[]       @relation("UserVehicles")
  driverRides       Ride[]          @relation("DriverRides")
  passengerBookings RideBooking[]   @relation("PassengerBookings")
  savedLocations    SavedLocation[] @relation("UserLocations")
  notifications     Notification[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DriverProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id])
  driverPhoto    String?
  aadharCard     String?
  drivingLicence String?
  vehiclePuc     String?
  vehicleFront   String?
  vehicleRear    String?
  status         String         @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model CompanySettings {
  id             String   @id @default(cuid())
  companyName    String   @default("Carpooling Inc")
  costPerKm      Float    @default(5.0)
  adminEmail     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Vehicle {
  id               String   @id @default(cuid())
  driverId         String
  driver           User     @relation("UserVehicles", fields: [driverId], references: [id])
  vehicleModel     String
  registrationNo   String
  seatingCapacity  Int
  createdAt        DateTime @default(now())
  
  Ride             Ride[]
}

model Ride {
  id              String   @id @default(cuid())
  driverId        String
  driver          User     @relation("DriverRides", fields: [driverId], references: [id])
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  
  // Geographical Data
  pickupLocation  String
  pickupLat       Float
  pickupLng       Float
  
  dropLocation    String
  dropLat         Float
  dropLng         Float
  
  travelDateTime  DateTime
  availableSeats  Int
  farePerSeat     Float
  status          String   @default("PUBLISHED") // PUBLISHED, ONGOING, COMPLETED, CANCELLED
  
  bookings        RideBooking[]
  createdAt       DateTime @default(now())
}

model RideBooking {
  id              String   @id @default(cuid())
  rideId          String
  ride            Ride     @relation(fields: [rideId], references: [id])
  passengerId     String
  passenger       User     @relation("PassengerBookings", fields: [passengerId], references: [id])
  
  seatsBooked     Int
  totalFare       Float
  
  // Passenger Specific Geographical Data
  passengerPickupLat Float?
  passengerPickupLng Float?
  passengerDropLat   Float?
  passengerDropLng   Float?
  
  // Driver Approval Flow
  status          String   @default("REQUESTED") // REQUESTED, APPROVED, REJECTED, COMPLETED, CANCELLED
  
  // Payment Flow
  paymentStatus   String   @default("PENDING") // PENDING, PAID, FAILED
  razorpayOrderId String?
  razorpayPaymentId String?

  createdAt       DateTime @default(now())
}

model SavedLocation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserLocations", fields: [userId], references: [id])
  name        String   // e.g., "Home", "Office"
  address     String
  lat         Float
  lng         Float
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  link      String?  // Optional URL associated with this notification
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Float    @default(0.0)
  
  transactions Transaction[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
  amount      Float
  type        String   // CREDIT or DEBIT
  description String
  createdAt   DateTime @default(now())
}
